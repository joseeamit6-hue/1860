rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. CMS Portfolio Configuration rules
    match /cms/data {
      // Portfolio details are public-read so visitors can see the website
      allow read: if true;

      // Only authenticated admin sessions are permitted to write/modify
      allow write: if request.auth != null;
    }
  }
}
